# GitHub Linguist configuration
# Count the GitHub Pages site as project source, not only documentation.
docs/**/*.html -linguist-documentation
docs/assets/**/*.css -linguist-documentation
docs/assets/**/*.js -linguist-documentation

# Structured data layer as project source (not documentation).
maint/src/**/*.ts -linguist-documentation
docs/project/database/**/*.sql -linguist-documentation
maint/data/**/*.yml -linguist-documentation
maint/schemas/**/*.json -linguist-documentation

# Treat release/build outputs as generated.
dist/** linguist-generated
*.zip linguist-generated
docs/assets/toolkit-manifest.json linguist-generated
.github/node-toolchain/package-lock.json linguist-generated

# Keep Markdown toolkit materials as documentation.
toolkit/**/*.md linguist-documentation
docs/**/*.md linguist-documentation

# Override: progress-note examples are vendored-style samples, not primary docs.
toolkit/examples/progress-notes/** linguist-vendored

# Keep common generated/local files out of meaningful stats.
*.bundle linguist-generated
*.tar.gz linguist-generated
