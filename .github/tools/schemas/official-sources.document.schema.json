{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/artemhobotun/EU-AI-Act-Toolkit/schemas/official-sources.document.schema.json",
  "title": "Official sources registry document",
  "description": "Root structure for data/official-sources.yml",
  "type": "object",
  "additionalProperties": false,
  "required": ["official_sources", "important_notes"],
  "properties": {
    "official_sources": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/officialSource" }
    },
    "important_notes": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "officialSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "source_type", "url", "institution", "use_for", "notes"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "source_type": {
          "type": "string",
          "enum": ["regulation", "guidance", "reference", "policy", "agency"]
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "institution": {
          "type": "string",
          "minLength": 1
        },
        "publication_date": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "use_for": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
