{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "vitest": ["./node_modules/vitest"],
      "vitest/*": ["./node_modules/vitest/*"]
    }
  },
  "include": ["../../src/**/*.ts"]
}
