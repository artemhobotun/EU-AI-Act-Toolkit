{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/artemhobotun/EU-AI-Act-Toolkit/schemas/toolkit-registry.document.schema.json",
  "title": "Toolkit registry document",
  "description": "Root structure for data/toolkit-registry.yml",
  "type": "object",
  "additionalProperties": false,
  "required": ["toolkit_resources"],
  "properties": {
    "toolkit_resources": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/toolkitResource" }
    }
  },
  "$defs": {
    "toolkitResource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "type",
        "path",
        "purpose",
        "description",
        "recommended_for",
        "review_level"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": ["pack", "reference", "guidance"]
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "recommended_for": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "review_level": {
          "type": "string",
          "enum": [
            "foundational",
            "moderate",
            "practical",
            "illustrative",
            "reference",
            "guidance"
          ]
        }
      }
    }
  }
}
